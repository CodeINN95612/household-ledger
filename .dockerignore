# Dependencies & build output (rebuilt inside the image)
node_modules
.next
out
prisma-dist

# Local database files — never bake these into the image
*.db
*.db-journal
prisma/*.db
prisma/*.db-journal

# Secrets & local env
.env
.env.*
!.env.example

# VCS / tooling / docs
.git
.gitignore
.claude
*.md
.dockerignore
# Docker definitions (the entrypoint IS needed in the context, so don't ignore it)
docker/Dockerfile
docker/docker-compose.yml

# Misc
.DS_Store
npm-debug.log*
.pnpm-debug.log*
coverage
