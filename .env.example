# SQLite database file. This file is the single backup target (spec §5).
# Local dev uses a file in the repo; in Docker/Dokploy it's set to the volume
# path (file:/data/app.db) — see docker-compose.yml.
DATABASE_URL="file:./dev.db"

# Secret used to sign Auth.js session JWTs. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Seed users (spec §5 — signup isn't needed for v1; two users are seeded at first boot).
SEED_USER1_EMAIL="you@example.com"
SEED_USER1_PASSWORD="change-me-1"
SEED_USER1_NAME="You"

SEED_USER2_EMAIL="partner@example.com"
SEED_USER2_PASSWORD="change-me-2"
SEED_USER2_NAME="Partner"
